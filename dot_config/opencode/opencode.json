{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ruff": {
      "command": ["uvx", "ruff", "server"],
      "extensions": [".py", ".pyi"]
    },
    "ty": {
      "command": ["uvx", "ty", "server"],
      "extensions": [".py", ".pyi"]
    }
  },
  "mcp": {
    "notion": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.notion.com/mcp"
    },
    "zotero": {
      "type": "local",
      "enabled": true,
      "command": ["uvx", "--from", "zotero-mcp-server", "zotero-mcp"],
      "environment": {
        "ZOTERO_LOCAL": "true"
      },
      "timeout": 120000
    }
  }
}
