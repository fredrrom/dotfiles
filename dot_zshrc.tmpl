# ---------- History / keys ----------
HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS SHARE_HISTORY INC_APPEND_HISTORY
bindkey -v

# ---------- Completion ----------
autoload -Uz compinit
compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# ---------- zinit ----------
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting
zinit light Aloxaf/fzf-tab

# ---------- OS-specific ----------
{{ if eq .chezmoi.os "darwin" }}
# fzf (Homebrew default)
source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
source "$(brew --prefix)/opt/fzf/shell/completion.zsh"
{{ else if eq .chezmoi.os "linux" }}
# fzf (system)
source /usr/share/fzf/key-bindings.zsh
source /usr/share/fzf/completion.zsh
# SSH agent socket
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR:-/run/user/$UID}/ssh-agent.socket"
. "$HOME/.local/bin/env"
{{ end }}
export FZF_DEFAULT_COMMAND='fd --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

# ---------- Useful defaults ----------
export EDITOR=nvim
alias grep="rg"

# ---------- functions ----------
# fcd: fuzzy cd
fcd() {
  local dir
  dir=$(fd -t d . ${1:-.} | fzf) || return
  cd "$dir"
}

# v: open a file from cwd
v() {
local f
f="$(fd --type f --hidden --exclude .git | fzf)"
[[ -n "$f" ]] && nvim "$f"
}


# cf: open a config file (~/.config + top-level dotfiles)
cf() {
local f
f="$(
fd --type f --hidden --exclude .git . "${XDG_CONFIG_HOME:-$HOME/.config}" \
| sed "s|^$HOME/|~/|" \
| fzf
)"
[[ -n "$f" ]] && nvim "${f/#\~/$HOME}"
}


# vg: grep -> open at line
vg() {
local sel file line
sel="$(rg --line-number --no-heading --smart-case "$*" | fzf)" || return
file="${sel%%:*}"
line="${sel#*:}"; line="${line%%:*}"
nvim +"$line" "$file"
}

# ---------- tmux ----------
if [[ -z "$TMUX" && -n "$PS1" ]]; then
  if tmux ls >/dev/null 2>&1; then
    tmux attach \; choose-tree -Zs
  else
    tmux new -s main
  fi
fi

. "$HOME/.local/bin/env"

# lean
if [[ -f "$HOME/.elan/env" ]]; then
  source "$HOME/.elan/env"
fi

# opencode
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# npm
export PATH="$HOME/.local/npm-global/bin:$PATH"
