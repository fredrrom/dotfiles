#!/bin/bash
# Install tools on macOS and Linux
# This script runs once when chezmoi is applied

set -e

echo "🔧 Installing tools..."

{{ if eq .chezmoi.os "darwin" -}}
# macOS installation via Homebrew
echo "📦 Detected macOS - using Homebrew"

# Check if Homebrew is installed
if ! command -v brew &> /dev/null; then
    echo "⚠️  Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

{{ $darwin := .packages.darwin }}
brew_taps=(
{{- range $darwin.taps }}
  "{{ . }}"
{{- end }}
)

brew_formulae=(
{{- range $darwin.brew }}
  "{{ . }}"
{{- end }}
)

brew_casks=(
{{- range $darwin.cask }}
  "{{ . }}"
{{- end }}
)

echo "📦 Installing Homebrew taps..."
for tap in "${brew_taps[@]}"; do
    brew tap "$tap"
done

echo "📦 Installing Homebrew formulae..."
if [ ${#brew_formulae[@]} -gt 0 ]; then
    brew install "${brew_formulae[@]}"
fi

echo "📦 Installing Homebrew casks..."
if [ ${#brew_casks[@]} -gt 0 ]; then
    brew install --cask "${brew_casks[@]}"
fi

echo "✅ Homebrew packages installed"

{{ else if eq .chezmoi.os "linux" -}}
# Linux installation
echo "🐧 Detected Linux - detecting package manager..."

{{ $linux := .packages.linux }}
linux_common=(
{{- range $linux.common }}
  "{{ . }}"
{{- end }}
)

filter_available_packages() {
    local manager="$1"
    shift
    local installable=()
    local skipped=()

    for pkg in "$@"; do
        case "$manager" in
            apt)
                if apt-cache show "$pkg" >/dev/null 2>&1; then
                    installable+=("$pkg")
                else
                    skipped+=("$pkg")
                fi
                ;;
            dnf)
                if dnf info "$pkg" >/dev/null 2>&1; then
                    installable+=("$pkg")
                else
                    skipped+=("$pkg")
                fi
                ;;
            pacman)
                if pacman -Si "$pkg" >/dev/null 2>&1; then
                    installable+=("$pkg")
                else
                    skipped+=("$pkg")
                fi
                ;;
            zypper)
                if zypper --non-interactive info "$pkg" >/dev/null 2>&1; then
                    installable+=("$pkg")
                else
                    skipped+=("$pkg")
                fi
                ;;
        esac
    done

    if [ ${#skipped[@]} -gt 0 ]; then
        echo "⚠️  Skipping unavailable packages: ${skipped[*]}"
    fi

    printf '%s\n' "${installable[@]}"
}

# Detect package manager and install
if command -v apt-get &> /dev/null; then
    echo "📦 Using apt (Debian/Ubuntu)"
    sudo apt-get update
    apt_packages=(
{{- range $linux.apt }}
      "{{ . }}"
{{- end }}
    )
    all_packages=("${linux_common[@]}" "${apt_packages[@]}")
    mapfile -t install_packages < <(filter_available_packages apt "${all_packages[@]}")
    if [ ${#install_packages[@]} -gt 0 ]; then
        sudo apt-get install -y "${install_packages[@]}"
    fi

elif command -v dnf &> /dev/null; then
    echo "📦 Using dnf (Fedora/RHEL)"
    dnf_packages=(
{{- range $linux.dnf }}
      "{{ . }}"
{{- end }}
    )
    all_packages=("${linux_common[@]}" "${dnf_packages[@]}")
    mapfile -t install_packages < <(filter_available_packages dnf "${all_packages[@]}")
    if [ ${#install_packages[@]} -gt 0 ]; then
        sudo dnf install -y "${install_packages[@]}"
    fi

elif command -v pacman &> /dev/null; then
    echo "📦 Using pacman (Arch Linux)"
    pacman_packages=(
{{- range $linux.pacman }}
      "{{ . }}"
{{- end }}
    )
    all_packages=("${linux_common[@]}" "${pacman_packages[@]}")
    mapfile -t install_packages < <(filter_available_packages pacman "${all_packages[@]}")
    if [ ${#install_packages[@]} -gt 0 ]; then
        sudo pacman -S --noconfirm "${install_packages[@]}"
    fi

elif command -v zypper &> /dev/null; then
    echo "📦 Using zypper (openSUSE)"
    zypper_packages=(
{{- range $linux.zypper }}
      "{{ . }}"
{{- end }}
    )
    all_packages=("${linux_common[@]}" "${zypper_packages[@]}")
    mapfile -t install_packages < <(filter_available_packages zypper "${all_packages[@]}")
    if [ ${#install_packages[@]} -gt 0 ]; then
        sudo zypper install -y "${install_packages[@]}"
    fi

else
    echo "⚠️  Unsupported package manager. Install packages manually."
    exit 1
fi

{{ end -}}

echo "✅ Tool installation complete!"
